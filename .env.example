# API keys for circuit-oracle experiments
# Copy this file to .env and fill in your keys:
#   cp .env.example .env

# LLM API key — set ONE of these depending on your provider:
#   --provider anthropic (default): uses ANTHROPIC_API_KEY
#   --provider openrouter:          uses OPENROUTER_API_KEY
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
NEURONPEDIA_API_KEY=
# HuggingFace token (for downloading model weights)
HF_TOKEN=
